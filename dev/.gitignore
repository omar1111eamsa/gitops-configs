# Local .terraform directories
**/.terraform/*

# Terraform lock file (opinions differ — many teams DO commit this one;
# excluding it here since we're keeping things simple for now)
.terraform.lock.hcl

# State files — contain secrets in plaintext, never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# terraform.tfvars often contains sensitive values (repo tokens, overrides) —
# never commit it; share it out-of-band or via a secrets manager instead
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc